<%# HTML fragment for the ajax modal (XHR requests). Matches Blacklight’s citation tool:
    render HTML with layout: false when request.xhr? — not format.js (text/javascript). %>
<div class="modal-header">
  <h3><%= t('blacklight.tools.citation') %></h3>
  <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
</div>
<div class="modal-body">

    <h3 class="modal-title"><%= @manuscript.public_id %></h3>

    <%= @manuscript.to_citation %><br/><br/>

    <p><em><b>Warning</b>: Manuscript Record id numbers are not
    permanent. Manuscript records may disappear if entries are
    unlinked.</em></p>
    
</div>

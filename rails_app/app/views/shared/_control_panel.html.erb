<div id="control-panel" class="collapse width in">
  <div class="scroll-box">
    <% if current_user %>
    <div class="card">
        <div class="card-header" style="white-space: nowrap; padding-top: 10px; background: #4d6b98;">
            <div class="user-icon">
              <%= image_tag "https://www.gravatar.com/avatar/#{Digest::MD5.hexdigest(current_user.email.downcase)}?s=128&d=mm", class: 'img img-fluid dashboard-profile-picture' %>
            </div>
            <div class="user-info">
              <span class="dropdown">
                <a href="" class="dropdown-toggle" data-toggle="dropdown" style="color: white;">
                  <%= current_user.to_s %>
                  <span class="caret"></span>
                </a>
                <ul class="dropdown-menu">
                  <li><a href="<%= main_app.profile_path(username: current_user.username) %>"><span class="fa fa-user"></span> My Profile</a></li>
                  <li><a href="<%= main_app.private_messages_path %>"><span class="fa fa-envelope"></span> My Messages</a></li>
                  <li><%= link_to main_app.edit_user_registration_path do %> <span class="fa fa-cog"></span> My Settings <% end %></li>
                  <% if current_user && !current_user.to_s.blank? %>
                    <li>
                      <%= link_to(main_app.destroy_user_session_path, :onclick => "localStorage.clear();") do %>
                        <span class="fa fa-sign-out"></span> <%= t('blacklight.header_links.logout') %>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              </span><br>
              <span class="text-muted" sdbm-tooltip="user_levels">User Level: <em><%= current_user.role %></em></span>
            </div>
        </div>
        <div class="card-body">
          <ul class="nav">
            <%= render partial: "nav/notifications" %>
            <li>
              <a href="<%= main_app.dashboard_contributions_path %>"><span class="fa fa-tachometer"></span> Dashboard</a>
            </li>
            <li>
                <a href="/bookmarks"><span class="fa fa-bookmark"></span> Bookmarks</a>
            </li>
            <li>
                <a href="/downloads"><span class="fa fa-floppy-o"></span> Exports</a>
            </li>
            <li>
                <a href="/groups"><span class="fa fa-globe"></span> Groups</a>
            </li>          
            <li>
                <a href="/watches"><span class="fa fa-eye"></span> Watched Records</a>
            </li>
            <li class='dropdown'>
              <a href="" data-toggle="dropdown"><span class="fa fa-inbox"></span> Projects <span class="caret"></span></a>
              <ul class="dropdown-menu" role="menu">
                <li>
                  <a href="/dericci_games"><span class="fa fa-building"></span> De Ricci Name Game</a>
                </li>
                <li>
                  <a href="/dericci_records"><span class="fa fa-list"></span> De Ricci Archive</a>
                </li>
                <li>
                  <a href="/names/problems"><span class="fa fa-exclamation-triangle"></span> Problem Names</a>
                </li>                
                <li>
                  <a href="/sparql-space"><span class="fa fa-certificate"></span> <b>SPARQL</b> Endpoint</a>
                </li>
              </ul>
            </li>
          </ul>
        </div>
    </div>

    <div class="control-panel-top">
      <div class="card show-tools">
        <div class="card-header"><span class="h4">Tools</span></div>
        <div class="card-body">
          <ul class="nav">
            <% if content_for? :add_entry %>
              <!--<li class="divider"></li>-->
              <%= yield :add_entry %>
            <% else %>
            <li class="dropdown">
              <a href="" data-toggle="dropdown"><span class="fa fa-plus"></span> Add New Entry <span class="caret"></span></a>
              <ul class="dropdown-menu" role="menu">
                <li>
                  <a href="/entries/new">From a Source</a>
                </li>
                <li>
                  <%= link_to "Based on Personal Observation", main_app.new_source_path({create_entry: 1, source_type: 4}) %>
                </li>
              </ul>
            </li>
            <% end %>
            <%= yield :control_tools %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

    <% if !current_user %>
    <div class="card" style="overflow: hidden;">
      <div class="card-header">
        <span class="h4">
          <span class="fa fa-sign-in"></span> Login
        </span>
      </div>
      <div class="card-body">
        <div style="padding: 0px 10px;">
          <%= render partial: 'devise/sessions/new', locals: {resource: User.new, resource_name: 'user', devise_mapping: Devise.mappings[:user]} %>      
        </div>
        <ul class="nav">
          <li>
            <%= link_to(new_registration_path('user')) do %>
              <span class="fa fa-sign-in"></span> Sign up
            <% end %>
          </li>
          <li>
            <%= link_to(new_password_path('user')) do %>
              <span class="fa fa-question-circle"></span> Forgot your password?
            <% end %>
          </li>
        </ul>
      </div>
    </div>
    <div class="card">
      <div class="card-header">
        <span class="h4">
          <span class="fa fa-link"></span>
          Related Links
        </span>
      </div>
      <div class="card-body">
        <ul class="nav">
          <li class='dropdown'>
            <a href="" data-toggle="dropdown"><span class="fa fa-inbox"></span> Projects <span class="caret"></span></a>
            <ul class="dropdown-menu" role="menu">
              <li>
                <a href="/dericci_games"><span class="fa fa-building"></span> De Ricci Name Game</a>
              </li>
              <li>
                <a href="/dericci_records"><span class="fa fa-list"></span> De Ricci Archive</a>
              </li>
              <li>
                <a href="/names/problems"><span class="fa fa-exclamation-triangle"></span> Problem Names</a>
              </li>
            </ul>
          </li>
          <li>
            <a href="https://schoenberginstitute.org/" title="The Schoenberg Institute for Manuscript Studies">
              <span class="fa fa-book"></span>
              The Schoenberg Institute for Manuscript Studies
            </a>
          </li>
          <li>
            <a href="http://dla.library.upenn.edu/dla/medren/search.html?fq=collection_facet%3A%22Lawrence%20J.%20Schoenberg%20Collection%22" title="Online digital facsimiles">
              <span class="fa fa-image"></span>
              Penn in Hand
            </a>
          </li>
          <li>
            <a href="http://openn.library.upenn.edu/html/0001.html" title="Downloadable digital images and metadata">
              <span class="fa fa-image"></span>
              OPenn
            </a>
          </li>
          <li>
            <a href="http://sceti.library.upenn.edu/ljscatalog/index.html" title="A printed catalog of early manuscripts">
              <span class="fa fa-folder"></span>
              Transformation of Knowledge
            </a>
          </li>
          <li>
            <a href="http://sceti.library.upenn.edu/legacy/" title="Online Exhibit">
              <span class="fa fa-graduation-cap"></span>
              A Legacy Inscribed
            </a>
          </li>
          <li>
            <a href="https://mappingmanuscriptmigrations.org/en/" class="href">
              <span class="fa fa-map-marker"></span>
              Mapping Manuscript Migrations
            </a>
          </li>
        </ul>
      </div>
    </div>
    <% end %>
    <div class="img-brands">
      <a href="https://diggingintodata.org/" target="_blank"><%= image_tag 'logo_did.png', class: "img img-neh img-did" %></a>
      <a href="https://www.neh.gov/" target="_blank"><%= image_tag 'logo_neh.png', class: "img img-neh" %></a>
      <a href="https://www.transatlanticplatform.com/" target="_blank"><%= image_tag 'logo_tap.png', class: "img img-neh" %></a>
      <a href="https://www.imls.gov/" target="_blank"><%= image_tag 'logo_imls.png', class: "img img-neh" %></a>
    </div>
  </div>
</div>
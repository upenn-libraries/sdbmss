<% content_for :head do %>
  <%= stylesheet_link_tag "extras", media: "all" %>
  <%= javascript_include_tag "extras" %>
<% end %>
<div ng-controller="ManageBookmarks" ng-init='search_term = "<%= params[:tag] %>"'>
<div class="row">
  <div class="col-sm-12 text-center">
    <h1><span class="fa fa-bookmark"></span> Bookmarks</h1>
  </div>
  <div class="col-sm-12">
    <%= render partial: "pages/partial", locals: {page_name: "Bookmark Instructions"} %>
  </div>
  <div class="col-sm-12">
    <ul class="nav nav-tabs">
      <li class="nav-item"><a class="nav-link active" href="#Entry" data-bs-toggle="tab">Entries <span class="badge text-bg-secondary">{{ all_bookmarks_display["Entry"].length }}</span></a></li>
      <li class="nav-item"><a class="nav-link" href="#Manuscript" data-bs-toggle="tab">Manuscript Records <span class="badge text-bg-secondary">{{ all_bookmarks_display["Manuscript"].length }}</span></a></li>
      <li class="nav-item"><a class="nav-link" href="#Source" data-bs-toggle="tab">Sources <span class="badge text-bg-secondary">{{ all_bookmarks_display["Source"].length }}</span></a></li>
      <li class="nav-item"><a class="nav-link" href="#Name" data-bs-toggle="tab">Names <span class="badge text-bg-secondary">{{ all_bookmarks_display["Name"].length }}</span></a></li>
      <li class="nav-item"><a class="nav-link" href="#DericciRecord" data-bs-toggle="tab">De Ricci Record <span class="badge text-bg-secondary">{{ all_bookmarks_display["DericciRecord"].length }}</span></a></li>
      <li class="ms-auto" style="max-width: 30%;">
        <span class="input-group">
          <input type="text" class="form-control" name="tag-search" placeholder="Filter By Tag..." size=32 ng-model="search_term" ng-keyup="$event.keyCode == 13 && searchTag(search_term)">
          <span class="input-group-append">
            <a href="" class="btn btn-primary bookmark-search" ng-click="searchTag(search_term)"><span class="fa fa-tag"></span> Filter</a>
            <a href="" class="btn btn-outline-secondary" ng-click="searchTag('')"><span>Clear</span></a>
          </span>
        </span>
      </li>
    </ul>
  </div>
  <div class="col-sm-12">
    <div class="tab-content">
      <div class="tab-pane fade" ng-class="{'show active' : name == 'Entry'}" id="{{ name }}" ng-repeat="(name, bookmarks) in all_bookmarks_display" style="padding-top: 10px;">

        <p class="text-muted text-center">You have {{ bookmarks.length }} bookmark{{ bookmarks.length == 1 ? '' : 's' }} of this type
          <span ng-if="tagSearch && tagSearch.length > 0"> with the tag <span class="btn btn-primary btn-sm" ng-click="searchTag(tagSearch)">{{ tagSearch }}</span></span>
        </p>

        <div class="row">
          <div class="col-sm-12 mb-4" ng-repeat="bookmark in bookmarks">
          <div class="card">
            <div class="card-header">
              <strong><a href="{{ bookmark.link }}">{{ bookmark.public_id }}</a></strong>
              <a class='remove-bookmark control-bookmark float-end' ng-click="removeBookmark(name, bookmark)" title="Remove bookmark">
                <span class="fa fa-times"></span>
              </a>
            </div>
            <div class="card-body">
              <dl class="document-metadata dl-horizontal dl-invert">
                <dt ng-repeat-start="(key, value) in bookmark.details track by $index">{{ key }}</dt>
                <dd ng-repeat-end>{{ value }}</dd>
              </dl>
            </div>
            <div class="card-footer">
              <div class="row">
                <div class="col-sm-7">
                  <ul class="list-inline" style="margin-bottom: 0px;">
                    <li class="list-inline-item"><span class="btn btn-sm"><span class="fa fa-tag"></span> Tags</span> </li>
                    <li ng-if="bookmark.tags.length <= 0" class="list-inline-item text-muted">This bookmark has no tags.</li>
                    <li ng-repeat="tag in bookmark.tags" class="list-inline-item btn-group">
                      <a class="btn btn-outline-secondary btn-sm" ng-class="{'btn-primary' : tag == tagSearch}" href="" ng-click="searchTag(tag);">{{ tag }}</a>
                      <a href="" class='btn btn-outline-secondary btn-sm remove-bookmark-tag-confirm small' ng-click="removetag(bookmark, tag)" title="Remove tag '{{ tag }}'"><span class="fa fa-times"></span></a>
                    </li>
                  </ul>
                </div>
                <div class="col-sm-5 text-end">
                  <a ng-show="!bookmark.showAddTag" href="" class="btn btn-sm btn-outline-secondary btn-add-tag" ng-click="bookmark.showAddTag = !bookmark.showAddTag">
                    <span class="fa fa-plus"></span> Add Tag
                  </a>
                  <div class="form-inline" style="position: absolute; right: 10px; top: -6px;">
                    <div class="input-group add-bookmark-tag" ng-show="bookmark.showAddTag">
                      <div class="input-group-prepend">
                        <span class="input-group-text text-muted">Tag:</span>
                      </div>
                      <input type='text' class='form-control new-bookmark-tag' placeholder="New tag..." ng-model="bookmark.newtag" ng-keyup="$event.keyCode == 13 && addtag(bookmark, bookmark.newtag)">
                      <div class="input-group-append">
                        <a href="" class="btn btn-outline-secondary add-bookmark-tag-confirm" ng-click="addtag(bookmark, bookmark.newtag)"><span class="fa fa-plus"></span> Add</a>
                        <a href="" class="btn btn-warning add-bookmark-tag-confirm" ng-click="bookmark.showAddTag = !bookmark.showAddTag">Cancel</a>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

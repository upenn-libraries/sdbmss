<%#
  OVERRIDE Blacklight v7.11.1 so that instructional text can be inserted
    and to use ul instead of table for listing searches
%>

<% @page_title = t('blacklight.search_history.page_title', :application_name => application_name) %>
<div class="row justify-content-center">
<div id="content" class="col-sm-10 searches">
<h2 class='page-heading'><%=t('blacklight.search_history.title')%></h2>

<p>This page lists all search facets you have used in your current
    SDBM session. You can clear your entire search history using
    the <b>Clear Search History</b> button.
</p>
<p>To view your saved searches, click the <b>Saved Searches</b> option under the My Searches dropdown in the top horizontal navigation.</p>

<%- if @searches.blank? -%>
  <h3 class='section-heading'><%=t('blacklight.search_history.no_history')%></h3>
<%- else -%>
    <%= link_to t('blacklight.search_history.clear.action_title'), blacklight.clear_search_history_path, :method => :delete, :data => { :confirm => t('blacklight.search_history.clear.action_confirm') }, :class => 'btn btn-danger float-end' %>
  <h3 class='section-heading'><%=t('blacklight.search_history.recent')%></h3>
  <ul class="list-group pt-2">
    <%-  @searches.each_with_index do |search,index| -%>
    <li class="list-group-item">
      <div class="row">
        <% normalized = SDBMSS::BlacklightAdvancedSearch::RedirectLegacyParamsFilter.normalize(search.query_params, blacklight_config) %>
        <% search_state = controller.search_state_class.new(normalized, blacklight_config, self) %>
        <span class="col-sm-12"><%= link_to(render(Blacklight::ConstraintsComponent.for_search_history(search_state: search_state)), search_action_path(search.query_params)) %></span>
      </div>
    </li>
  <%- end -%>
  </ul>
<%- end -%>
</div>
</div>

<% new_count = current_user.new_notifications.count %>
<li class="dropdown">
<a id='notifications-dropdown-control' href="#notifications-dropdown" data-toggle="collapse" class='<%= new_count > 0 ? 'notifications-count' : ''%>' new-notifications="<%= current_user.new_notifications.count %>">
  <span class="fa fa-bell"></span> Notifications
  <span class="fa fa-caret-down"></span>
</a>
<div class="collapse" id="notifications-dropdown">
  <%= render partial: "notifications/index", locals: {notifications: current_user.notifications.where(active: true).last(10).reverse } %>
  <div class='text-center'><%= link_to "Manage Notifications", main_app.notifications_path, class: "btn btn-sm btn-primary" %></div>
</div>
</li>

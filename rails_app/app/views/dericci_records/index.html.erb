<% content_for :control_tools do %>
  <% if can? :manage, DericciRecord %>
  <li>
    <%= link_to(new_dericci_record_path) do %>
      <span class="fas fa-fw fa-plus"></span> New De Ricci Record
    <% end %>
  </li>
  <% end %>
<% end %>
<% content_for :breadcrumbs do %>
  <%= render partial: "dericci_games/breadcrumbs" %>
<% end %>
<div class="row">
  <div class="col-sm-12">
    <%= render partial: "pages/partial", locals: {page_name: "De Ricci Archive" } %>
  </div>
</div>
<%= form_tag dericci_records_path, :method => 'get', class: "form-inline" do %>
<div class="row" style="margin-bottom: 10px;">
  <div class="col-sm-12 d-flex flex-wrap justify-content-center align-items-center">
      <% if can? :manage, DericciRecord %>
        <label for="" class="form-label me-2 mb-0">
          Flagged
          <%= check_box_tag 'flagged', true, params[:flagged], class: 'ms-1' %>
        </label>
        <label for="" class="form-label me-2 mb-0">
          Unverified
          <%= check_box_tag 'verified_id', nil, params[:verified_id], class: 'ms-1' %>
        </label>
        <label for="" class="form-label me-2 mb-0">
          Linked
          <%= check_box_tag 'linked', nil, params[:linked], class: 'ms-1' %>
        </label>
        <label for="" class="form-label me-3 mb-0">
          In Scope
          <%= check_box_tag 'in_scope', nil, params[:in_scope], class: 'ms-1' %>
        </label>
      <% end %>
      <%= select_tag "field", options_for_select({"Name" => "name","Date" => "dates","Place" => "place"}, params[:field]), class: "form-control form-control-sm me-1", style: "width: auto;" %>
      <%= text_field_tag :term, params[:term], class: "form-control form-control-sm me-1", style: "width: auto;" %>
      <%= submit_tag "Search", :name => nil, class: "btn btn-primary btn-sm me-1", id: "search-dericci" %>
      <%= link_to "Clear", dericci_records_path, class: "btn btn-warning btn-sm" %>
  </div>
  <div class="col-sm-12 d-flex justify-content-center mt-2">
    <label for="" class="form-label me-3 mb-0">Repositories <%= radio_button_tag :type, '901/2', params[:type] == '901/2', class: 'ms-1' %></label>
    <label for="" class="form-label me-3 mb-0">Collectors <%= radio_button_tag :type, '901/3', params[:type] == '901/3', class: 'ms-1' %></label>
    <label for="" class="form-label mb-0">Show All <%= radio_button_tag :type, '', params[:type] == '' || params[:type] == nil, class: 'ms-1' %></label>
  </div>
</div>
<div class="row">
  <div class="col-sm-12 d-flex justify-content-center">
    <ul class="pagination justify-content-center flex-wrap">
      <% ('a'..'z').to_a.each do |letter| %>
        <li class='page-item <%= letter == params[:letter] ? "active" : "" %>'><%= link_to letter.capitalize, request.params.merge(:letter => letter).except(:page), class: "page-link" %></li>
      <% end %>
      <li class='page-item <%= !params[:letter] ? "active" : "" %>'><%= link_to "All", request.params.except(:letter).except(:page), class: "page-link" %></li>
    </ul>
  </div>
  <div class="col-sm-3">
    Showing <%= @offset %> to <%= [@offset + @count, @total].min %> of <%= @total %>
  </div>
  <div class="col-sm-6 text-center">
    <%= render partial: "shared/pagination", locals: {page: @page, pages: @num_pages, model_class: DericciRecord, action: nil } %>   
  </div>
  <div class="col-sm-3 text-end">
    Show <%= select_tag "limit", options_for_select([10, 20, 50, 100], params[:limit]), class: "form-control form-control-sm d-inline-block", style: "width: auto;" %>
  </div>
</div>
<% end %>
<div class="row">
  <div class="col-sm-12">
    <table class="table sdbm-table">
      <thead>
        <tr>
          <th>Name</th>
          <th></th>
          <th># Cards</th>
          <th>File Size</th>
          <th>SDBM Links</th>
          <th class="text-end">Dates</th>
        </tr>
      </thead>
      <tbody>
      <% if @total <= 0 %>
        <tr>
          <td colSpan="6" class="text-muted text-center">No matching records found.</td>
        </tr>
      <% end %>
      <% @records.each do |record| %>
          <%= render partial: "row", locals: {record: record} %>
      <% end %>
      </tbody>
    </table>
  </div>
</div>
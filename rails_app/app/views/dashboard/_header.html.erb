<% is_contributor = current_user.role == 'contributor' %>
<% possessive = is_contributor ? "Your" : "" %>
<% content_for :head do %>
    <% if current_user.active_survey %>
        <script>
        $(document).ready(function () {
            if (localStorage.getItem('sdbm_hide_survey') !== "1") {
                $('#Survey').modal('show');
            }
            $('#Survey').on('hidden.bs.modal', function () {
                localStorage.setItem('sdbm_hide_survey', "1");
                <% if current_user %>
                    $.ajax({
                        url: "<%= account_path(current_user) %>.json",
                        data: {user: { active_survey: false }},
                        method: 'put',
                        success: function (data) {
                            //console.log(data, 'success!');
                        }
                    })
                <% end %>
            });
        });
        </script>
    <% end %>
<% end %>

<% if current_user.active_survey %>
<div class="modal fade" id="Survey">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <iframe src="https://docs.google.com/forms/d/e/1FAIpQLSdVlU5AUc8O1b9uNnKRZLgb5sIIIClH8vwb_dg3HgVeJaVRhw/viewform?embedded=true" width="760" height="2200" style="width: 100%;" frameborder="0" marginheight="0" marginwidth="0">Loading...</iframe>
            </div>
        </div>
    </div>
</div>
<% end %>

<div class="row">
    <div class="col-sm-12 text-center">
        <%= image_tag "https://www.gravatar.com/avatar/#{Digest::MD5.hexdigest(current_user.email.downcase)}?s=128&d=mm", class: 'img img-fluid dashboard-profile-picture' %>
        <span class='h1 dashboard-header text-muted'><%= current_user.to_s %>'s Dashboard</span>
        <ul class="list-inline" style="margin-bottom: 0px;">
            <li class="list-inline-item">
                <span class="btn btn-info btn-sm btn-tag">
                    <span class="fa fa-tag"></span>
                </span> Tags:
            </li>
            <% if current_user.tags.count <= 0 %>
                <li class="list-inline-item">
                    <span class="text-muted">You do not have any tags yet.</span>
                </li>
            <% end %>
        <% current_user.tags.each do |tag| %>
            <li class="list-inline-item">
                <div class="btn-group">
                <%= link_to(main_app.bookmarks_path(tag: tag[0]), class: "btn btn-sm btn-secondary") do %>
                    <%= "#{tag[0]}" %>
                <% end %>
                <span class="btn btn-sm btn-info btn-tag">
                    <%= tag[1] %>
                </span>
                </div>
            </li>
        <% end %>
        </ul>
    </div>
</div>

<div class="row">
    <div class="col-sm-12">
        <ul id='dashboard-tabs' class="nav nav-tabs dashboard-tabs">
            <li class="nav-item">
                <a class="nav-link <%= request.original_fullpath == main_app.dashboard_contributions_path ? 'active' : ''%>" href="<%= main_app.dashboard_contributions_path %>"><span class="fa fa-gift"></span> Contributions</a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= request.original_fullpath == main_app.dashboard_activity_path ? 'active' : ''%>" href="<%= main_app.dashboard_activity_path %>"><span class="fa fa-eye"></span> Activity</a>
            </li>
            <!--<li><a data-toggle='tab' href="#groups" data-url="/groups/show_all">Groups</a></li>
            <li><a data-toggle='tab' href="#notifications">Notifications</a></li>-->
        </ul>
    </div>
</div>

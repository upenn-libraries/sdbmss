<% content_for :head do %>
  <style>
    .pagination {
      margin: 0px;
    }
    .notification-btn {
      width: 100%;
      margin-bottom: 5px;
    }
    .notification-btn .btn:first-child {
      width: calc(100% - 214px);
      text-align: left;
    }
  </style>
<% end %>
<% content_for :breadcrumbs do %>
  <li class="breadcrumb-item active"><%= link_to "Manage Notifications", notifications_path %></li>
  <li class="breadcrumb-item"><%= link_to main_app.edit_user_registration_path do %> <span class="fa fa-cog"></span> Notification Settings <% end %></li>
<% end %>
<div class="row">
  <div class="col-sm-12 text-center">
    <h3 class="h3 text-center">
      Notifications
      <br>
      <small><span class="text-info"><%= @unread %> Unread</span>, <span class="text-muted"><%= @total %> Total</span></small>
    </h3>
    <p class="text-muted">Notifications are sent in response to various actions and events that can happen in the database and our community.  You can control when and how you receive your notifications from your user settings.</p>
  </div>
  <!-- note: decent pagination system, for reuse maybe? -->
  <div class="col-sm-6">
    <%= render partial: "shared/pagination", locals: {page: @page, pages: @pages, model_class: Notification, action: nil } %>
  </div>
  <div class="col-sm-6 text-end">
    <div class="btn-group">
      <%= link_to read_many_notifications_path(ids: @notifications.map(&:id), active: false, page: @page), class: 'btn btn-outline-secondary' do %>
        <span class="fa fa-check-circle"></span> Mark All On Page As Read
      <% end %>
      <%= link_to delete_many_notifications_path(ids: @notifications.map(&:id), page: @page), :method => :delete, class: 'btn btn-danger' do %>
        <span class="fa fa-times"></span> Delete All On Page
      <% end %>
    </div>
  </div>
  <div class="col-sm-12 mt-1">
<% if @notifications.count <= 0 %>
  <div class="text-center alert alert-info">You have no notifications.</li>
<% end %>
<% @notifications.each do |notification| %>
  <div class="btn-group notification-btn">
    <% if notification.title %>
      <div class="btn-outline-secondary btn one-line text-start">
        <% if notification.notified %>
          <%
            if notification.notified.class == User
              url = main_app.profile_path(notification.notified.username)
            else
              url = main_app.polymorphic_url(notification.notified)
            end
          %>
          <%= link_to url, :title => notification.title do %>
            <% if notification.active %>
              <span class="fa fa-exclamation-circle"></span>
              <span class="title"><%= notification.title %></span>
            <% else %>
              <span class="title"><%= notification.title %></span>
            <% end %>
          <% end %>
        <% else %>
          <span class="title text-muted"><span class="fa fa-exclamation-triangle text-warning"></span> <%= notification.title %></span>
        <% end %>
        <%= notification.created_at.to_formatted_s(:long) %>
      </div>
      <% if notification.active %>
        <%= link_to notification_path(notification, active: false), method: :put, class: 'btn btn-outline-secondary' do %>
          <span class="fa fa-check-circle"></span> Mark as Read
        <% end %>
      <% else %>
        <a class="btn btn-outline-secondary disabled"><span class="fa fa-check-circle"></span> Mark as Read</a>
      <% end %>
      <%= link_to(notification_path(notification, format: 'html'), method: :delete, class: "btn btn-danger") do %>
        <span class="fa fa-times"></span> Delete
      <% end %>
    <% end %>
  </div>
<% end %>
  </div>
</div>

<%#
  OVERRIDE Blacklight 7.11: main column before sidebar for responsive layout; omits BL sitelinks
    shared/sitelinks_search_box on the home view. Stock uses content_for(:sidebar).
%>
<div id="content" class="<%= main_content_classes %>">
  <% unless has_search_parameters? %>
    <%# if there are no input/search related params, display the "home" partial -%>
    <%= render 'home' %>
  <% else %>
    <%= render 'search_results' %>
  <% end %>
</div>

<div id="sidebar" class="<%= sidebar_classes %>">
  <%= render 'search_sidebar' %>
</div>

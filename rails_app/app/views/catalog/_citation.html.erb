<%#
  OVERRIDE Blacklight v6.25.0: citation body comes from Entry model_object.to_citation; stock partial
    uses document export_as_mla/apa/chicago_citation_txt when defined on SolrDocument.
%>
<div class="modal-header">
  <button type="button" class="blacklight-modal-close close" data-dismiss="modal" aria-label="<%= t('blacklight.modal.close') %>">
    <span aria-hidden="true">&times;</span>
  </button>
  <h2><%= t('blacklight.tools.citation') %></h2>
</div>
<div class="modal-body">
  <% @documents.each do |document| %>
    <h3 class="modal-title"><%= document_heading(document) %></h3>
    <%= document.model_object.to_citation %><br/><br/>
  <% end %>
</div>

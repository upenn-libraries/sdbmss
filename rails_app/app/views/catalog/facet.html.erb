<%#
  OVERRIDE Blacklight 9.0.0: full-page facet browse (not modal): constraints, pagination, custom A–Z
    prefix strip, and FacetComponent. Stock facet.html.erb uses Blacklight::System::ModalComponent.
%>

<%= render blacklight_config.view_config(document_index_view_type).constraints_component.new(search_state: search_state) %>

<div class="facet_pagination top mb-2">
  <%= render Blacklight::FacetFieldPaginationComponent.new(facet_field: @presenter) %>
</div>

<h3>Browsing facet: <%= facet_field_label(@facet.key) %></h3>

<% if params[:"facet.sort"] == 'index' %>
<div style="margin-bottom: 10px">
Prefix:
<% prefix = params[:prefix] || 'all' %>
<% (prefixes = ['all'] + ('A'..'Z').to_a).each do |ch| %>
    <% if ch == prefix %><b><% end %><%= link_to_if(ch != prefix, ch, params_for_prefix_url(ch)) %><% if ch == prefix %></b><% end %>
    <% if ch != prefixes.last %> | <% end %>
<% end %>
</div>
<% end %>

<div>
  <div class="facet_extended_list">
      <%= (facet_values = render(Blacklight::FacetComponent.new(display_facet: @display_facet, blacklight_config: blacklight_config, layout: false))) %>
      <% if facet_values.blank? %>
          Nothing to display.
      <% end %>
  </div>
</div>

<div>
  <div class="facet_pagination bottom">
    <%= render Blacklight::FacetFieldPaginationComponent.new(facet_field: @presenter) %>
  </div>
</div>

<%#
  OVERRIDE Blacklight 9.0.0 to add constraints to advanced search form
%>

<% @page_title = t('blacklight.advanced_search.page_title', application_name: application_name) %>

<div class="advanced-search-form col-sm-12">
  <h1>
      <%= t('blacklight.advanced_search.form.title') %>
  </h1>

  <%= render blacklight_config.view_config(:search).constraints_component.new(search_state: search_state) %>

  <div class="row">
    <div class="col-md-8">
        <%= render 'advanced_search_form' %>
    </div>

    <div class="col-md-4">
        <%= render "advanced_search_help" %>
    </div>
  </div>
</div>

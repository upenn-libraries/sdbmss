<%#
  App catalog partial (no Blacklight default): show Save Search only for signed-in users with a
    meaningful query (same rules as add_to_search_history); avoids RecordNotFound from stale ids
    when browsing with no q/facets/advanced fields.
%>

<% if current_user && current_search_is_saveable? %>
  <%= button_to "Save Search", blacklight.save_search_path(search_session["id"]), :method => :put, :class => 'btn btn-secondary float-right' %>
<% end %>

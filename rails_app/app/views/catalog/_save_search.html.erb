<%#
  App catalog partial (no Blacklight default): show Save Search only for signed-in users; avoids
    exposing the control to guests while mirroring BL save_search_path behavior.
%>

<% if current_user %>
  <%= button_to "Save Search", blacklight.save_search_path(Search.find(search_session["id"])), :method => :put, :class => 'btn btn-default pull-right' %>
<% end %>

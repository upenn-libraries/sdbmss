<%#
  OVERRIDE Blacklight 7.11: facet "more" link is full-page navigation (no blacklight-modal trigger).
    Uses search_facet_path and explicit prefix for A–Z facet browsing on the app's facet page.
    Stock partial delegates to Blacklight::FacetFieldListComponent with modal trigger.
%>
<ul class="facet-values list-unstyled">
  <% paginator = Blacklight::FacetFieldPresenter.new(facet_field, display_facet, self).paginator %>
  <% facet_config = facet_configuration_for_field(field_name) %>
  <%= render facet_item_component_class(facet_config).with_collection(
        paginator.items.map { |item| facet_item_presenter(facet_config, item, field_name) },
        wrapping_element: :li
      ) %>

  <% unless paginator.last_page? || params[:action] == "facet" %>
    <li class="more_facets_link">
      <%= link_to t("more_#{field_name}_html", scope: 'blacklight.search.facets', default: :more_html, field_name: facet_field.label),
        search_facet_path(id: field_name, prefix: nil) %>
    </li>
  <% end %>
</ul>

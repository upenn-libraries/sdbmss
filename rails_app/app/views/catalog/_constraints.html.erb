<%#
  OVERRIDE Blacklight v6.9.0: start-over link resets to search_field=all_fields (and utf8) so simple
    search matches the app's default field; stock partial uses start_over_path without those params.
%>
<% if query_has_constraints? %>

      <div id="appliedParams" class="clearfix constraints-container">
        <div class="pull-right">
          <%=link_to t('blacklight.search.start_over'), start_over_path + "?search_field=all_fields&utf8=%E2%9C%93", :class => "catalog_startOverLink btn btn-primary btn-text", :id=>"startOverLink" %>
        </div>
        <span class="constraints-label"><%= t('blacklight.search.filters.title') %></span>
        <%= render_constraints(params) %>
      </div>
<% end %>
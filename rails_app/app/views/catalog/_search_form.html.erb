<%#
  OVERRIDE Blacklight 7.11: SDBM search action URL, hidden search_field=all_fields, advanced search
    button, and responsive navbar layout. Stock partial delegates to Blacklight::SearchBarComponent.
%>
<div class="navbar-header catalog-search-form w-100">
  <%= form_tag sdbmss_search_action_path, :method => :get, :class => 'form-inline clearfix navbar-form', :style => 'width: 100%;' do %>
    <%= render_hash_as_hidden_fields(search_state.params_for_search.except(:q, :search_field, :qt, :page, :utf8)) %>

    <% unless search_fields.empty? %>
      <input type="hidden" name="search_field" value="all_fields"/>
    <% end %>
    <div class="row w-100">
      <div class="col-11 col-md-12">
        <div class="input-group">
             <%= text_field_tag :q, params[:q], :placeholder => 'Search database...', :class => "search_q q form-control", :id => "q", :autofocus => should_autofocus_on_search_box? %>

          <div class="input-group-append">
            <button type="submit" class="btn btn-primary search-btn" id="search" style="white-space: nowrap;">
              <span class="submit-search-text"><%=t('blacklight.search.form.submit')%></span>
              <i class="fa fa-search"></i>
            </button>
            <a href="<%= main_app.advanced_search_path(search_state.params_for_search) %>" class="btn btn-light advanced_search">Advanced</a>
          </div>
        </div>
      </div>
      <div class="col-1 text-center show-mobile" style="padding: 0px">
        <a class='btn btn-blank navbar-toggler' data-toggle="collapse" data-target="#myNavbar">
          <i class="fa fa-ellipsis-h"></i>
        </a>
      </div>
    </div>
  <% end %>
</div>

<%#
  App catalog partial (no Blacklight default): client-side save-current-search button wired to
    saveCurrentSearch() when @my_search is present.
%>
<%= search_session %>
<% if @my_search %>
  <button search="<%= @my_search.id %>" class="btn btn-secondary" id="save_current_search" onClick="saveCurrentSearch();">Save Search</button>
<% end %>
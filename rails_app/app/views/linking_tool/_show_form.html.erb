<div class="navbar-right d-flex flex-column flex-md-row flex-md-wrap align-items-stretch align-items-md-start ms-md-auto">

<ul class="nav navbar-nav float-start mt-1">
    <li>
        <a href="" class="text-nowrap" id="addSearch">
            <span class="fa fa-plus"></span> add term
        </a>
    </li>
</ul>


<div class="search-form form-inline search-fieldset d-flex flex-column float-start" id="table-search-form">
    <div class="search-block input-group flex-column flex-md-row">
        <div class="input-group-append">
            <button type='button' class="btn btn-warning search-remove"> <span class="fa fa-times"></span> </button>
        </div>
        <%= text_field_tag :search_value, params[:search_value], placeholder: "Enter your search term...", class: "form-control form-control-sm" %>
        <select class="form-select form-select-sm w-auto" name="search_field">
        <% Array(@search_fields).each do |field| %>
            <option value="<%= field[1] %>" type="<%= @fields.include?(field) ? 'field' : (@filters.include?(field) ? 'filter' : 'date') %>"><%= field[0] %></option>
        <% end -%>
        </select>
        <select class="form-select form-select-sm w-auto me-md-2" name="search_option">
        <% Array(@filter_options).each do |option| %>
            <option value="<%= option %>" class="option filter_option">
                <% if option == 'with' %>
                    <%= "Equals" %>
                <% elsif option == 'without' %>
                    <%= "Does Not Equal" %>
                <% else %>
                    <%= option.humanize %>
                <% end %>
            </option>
        <% end %>
        <% Array(@field_options).each do |option| %>
            <option value="<%= option %>" class="option field_option"><%= option.humanize %></option>
        <% end %>
        <% Array(@date_options).each do |option| %>
            <option value="<%= option %>" class="option date_option"><%= option.humanize %></option>
        <% end %>
        </select>
    </div>
</div>

<div class="form-inline float-start">
    <div class="input-group form-submission d-flex flex-nowrap align-items-center">
        <select name="op" id="search_op" class="form-select form-select-sm">
            <option value="AND">All</option>
            <option value="OR">Any</option>
        </select>
        <div class="input-group-append">
            <button id="search_submit" type="submit" class="btn btn-primary">
                <span class="hide-mobile">Search</span>
                <span class="fa fa-search"></span>
            </button>
        </div>
    </div>
</div>

</div>

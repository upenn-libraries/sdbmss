<div class="row">
  <% summary.each_with_index do | (field, value), index| %>
    <div class="col-sm-4">
      <div class="card">
        <div class="card-header" data-toggle='collapse' href="#id_<%= field %>">
          <div class="card-title"><span class="h4"><%= field.to_s.humanize %>: <%= value[:total] %><span class="float-right fa fa-chevron-down"></span></span></div>
        </div>
        <div class="collapse" id="id_<%= field %>">
          <ul class="list-group list-group-no-border">
            <% value.each do |f, v| %>
              <% if f != :total %>
                <li class="list-group-item"><strong><%= field != :active_users ? f.to_s.humanize.pluralize : f.to_s %>:</strong> <%= v %></li>
              <% end %>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>
</div>

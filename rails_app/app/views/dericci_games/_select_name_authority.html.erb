<script type="text/ng-template" id="selectNameAuthority.html">
    <div class="modal-header d-block">
        <div class="d-flex justify-content-between align-items-start">
            <h3 class="modal-title">Find '{{ nameSearchString }}' in SDBM Name Authority</h3>
            <button type="button" class="close" data-dismiss="dialog" data-ng-click="cancel($event)">
                <span aria-hidden="true">&times;</span>
                <span class="sr-only">Close</span>
            </button>
        </div>
        <form class='input-group' ng-submit="autocomplete()">
            <input autofocus type="text" id="searchNameAuthority" class="form-control form-control-sm" ng-model="nameSearchString">
            <div class='input-group-append'>
                <input type='submit' class='btn btn-outline-secondary btn-sm' value='Search' id='search-name'>
            </div>
        </form>
    </div>
    <div class="modal-body form-horizontal compress-whitespace fit-screen">

    <div class="row" style="height: 100%;">
        <div class='col-sm-12' style="height: 100%;">
            <table class='table table-sm' style="margin-bottom: 0px; height: 100%;" id="select-name-table">
                <thead style="background: darkcyan; color: white;">
                    <tr>
                        <th style="width: 90px;">
                            <div class="btn-group">
                                <a href="" ng-disabled="page <= 1" ng-click="prevPage()" class="btn btn-sm btn-outline-secondary"><span class="fa fa-chevron-left"></span></a>
                                <span class="btn btn-sm btn-outline-secondary">{{ page }}</span>
                                <a href="" ng-click="nextPage()" class="btn btn-sm btn-outline-secondary"><span class="fa fa-chevron-right"></span></a>
                            </div>
                        </th>
                        <th class='text-left'>Name</th>
                        <th>VIAF ID</th>
                        <th title="As Author">Auth.</th>
                        <th title="As Artist">Art.</th>
                        <th title="As Scribe">Scrb.</th>
                        <th title="As Provenance Agent">Prov.</th>
                        <th title="As Source Agent">Src.</th>
                        <th>Reviewed</th>
                        <th>Confirmed</th>
                    </tr>
                </thead>
                <tbody>
                    <tr ng-show="warning.length > 0">
                        <td colspan="9">{{ warning }}</td>
                    </tr>
                    <tr ng-repeat="s in suggestions track by $index" >
                        <td><a class='selectName btn btn-success btn-sm' ng-click='selectSuggestion(s)'><span class='fa fa-check'></span> Link</a></td>
                        <td class='text-left'><a href="/names/{{ s.id }}" target="_blank">{{ s.name }}</a></td>
                        <td>{{ s.viaf_id }}</td>
                        <td>{{ s.authors_count }}</td>
                        <td>{{ s.artists_count }}</td>
                        <td>{{ s.scribes_count }}</td>
                        <td>{{ s.provenance_count }}</td>
                        <td>{{ s.source_agents_count }}</td>
                        <td>{{ s.reviewed ? "Yes" : "No" }}
                            <!--<span class='fa' ng-class="s.reviewed ? 'fa-check' : 'fa-times'"></span>-->
                        </td>
                        <td>{{ s.confirmed ? "Yes" : "No" }}
                            <!--<span class='fa' ng-class="s.confirmed ? 'fa-check text-success' : 'fa-times'"></span>-->
                        </td>
                    </tr>
                </tbody>
                <tfoot>
                </tfoot>
            </table>
        </div>
    </div>

    </div>
    <div class="modal-footer">
        <div class='w-100'>
            <div class="cantfind fade text-center mb-2">
                <span class='text-muted'>Should '{{ nameSearchString }}' be added to the SDBM Name Authority?</span>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                <a href="" ng-click="cantFind()" id="cantfindtoggle" class="btn btn-outline-secondary">Can't find the name?</a>
                <span class="btn-group cantfind fade">
                    <button class="btn btn-info" id="flag-add" ng-click="flag(current_record, 'The name described here should be added to the SDBM Name Authority')">Yes</button>
                    <button class="btn btn-warning" id="flag-scope" ng-click="flag(current_record, 'The names or information contained are not relevant or applicable to names in the SDBM')">No</button>
                    <button class="btn btn-outline-secondary" id="skip" ng-click="skip(current_record)">Not Sure</button>
                </span>
            </div>
        </div>
    </div>
</script>

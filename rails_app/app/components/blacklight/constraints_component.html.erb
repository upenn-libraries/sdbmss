<%# OVERRIDE Blacklight 8.12.3: skip facet_constraints in the top bar — they render
     in the sidebar "Selected Filters" card instead (sidebar_component override).
%>
<%= content_tag @tag || :div, id: @id, class: @classes do %>
  <% if @render_headers %>
    <h2 class="visually-hidden visually-hidden"><%= t('blacklight.search.search_constraints_header') %></h2>
  <% end %>

  <%= render ::SDBMSS::StartOverButtonComponent.new if @start_over_component %>

  <% if @render_headers %>
    <span class="constraints-label visually-hidden visually-hidden"><%= t('blacklight.search.filters.title') %></span>
  <% end %>
  <% if query_constraints_area.present? %>
    <% query_constraints_area.each do |constraint| %>
      <%= constraint %>
    <% end %>
  <% else %>
    <%= query_constraints %>
  <% end %>

  <% additional_constraints.each do |constraints| %>
    <%= constraints %>
  <% end %>
<% end %>

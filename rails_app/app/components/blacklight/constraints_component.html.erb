<%# OVERRIDE Blacklight 9.0.0: skip facet_constraints in the top bar — they render
     in the sidebar "Selected Filters" card instead (sidebar_component override).
     Use SDBMSS::StartOverButtonComponent instead of default.
%>
<%= content_tag @tag || :div, id: @id, class: @classes do %>
  <% has_query = @search_state.query_param.present? || @search_state.clause_params.any? %>
  <%= constraints_heading if has_query %>

  <% if query_constraints_area.present? %>
    <% query_constraints_area.each do |constraint| %>
      <%= constraint %>
    <% end %>
  <% else %>
    <%= query_constraints %>
  <% end %>

  <% unless @start_over_component %>
    <%= facet_constraints %>
  <% end %>

  <% additional_constraints.each do |constraints| %>
    <%= constraints %>
  <% end %>

  <%= render ::SDBMSS::StartOverButtonComponent.new if @start_over_component %>
<% end %>

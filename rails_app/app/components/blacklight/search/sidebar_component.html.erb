<%# OVERRIDE Blacklight 9.0.0: add "Selected Filters" card above facets when facet
     filters are active. Original SDBMSS feature from 2016 (51e8e7f7).
%>
<search>
  <% if params[:f].present? %>
    <div class="facets accordion">
      <div class="accordion-item facet-limit facet-limit-active">
        <h3 class="accordion-header p-0 facet-field-heading h6" id="selected-facets-header">
          <button type="button"
            class="btn accordion-button"
            data-bs-toggle="collapse"
            data-bs-target="#selected-facets"
            aria-expanded="true" aria-controls="selected-facets">
            Selected Filters
          </button>
        </h3>
        <div id="selected-facets" role="region" aria-labelledby="selected-facets-header"
          class="panel-collapse facet-content collapse show">
          <div class="accordion-body">
            <ul class="list-unstyled facet-values">
              <%= helpers.render_constraints_filters_side(params) %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% facet_group_names.each do |groupname| %>
    <% fields = facet_fields_in_group(groupname) %>
    <%= render group_component_class.new(id: groupname) do |component| %>
      <% component.with_body do %>
        <%= render Blacklight::FacetComponent.with_collection(fields, response: response) %>
      <% end %>
    <% end %>
  <% end %>
</search>
